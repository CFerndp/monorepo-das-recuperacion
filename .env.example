# .env.example (raíz del monorepo)
#
# Este fichero es una REFERENCIA RÁPIDA de todas las variables de entorno
# que existen en el proyecto, organizadas por servicio.
#
# Para desarrollo local y para Docker Compose NO necesitas crear ningún
# fichero .env en la raíz: cada servicio tiene sus propios defaults y
# el docker-compose.yml tiene todo configurado.
#
# Consulta los .env.example de cada servicio para más detalle:
#   - backend/.env.example   (variables del backend Django)
#   - frontend/.env.example  (variables del frontend Next.js)

# ------------------------------------------------------------------
# BACKEND (Django)    →  ver backend/.env.example
# ------------------------------------------------------------------

# Selector de base de datos: "false" = SQLite (local), "true" = PostgreSQL (Docker)
USE_POSTGRES=false

# Conexión a PostgreSQL (solo necesario si USE_POSTGRES=true)
POSTGRES_DB=das_db
POSTGRES_USER=das_user
POSTGRES_PASSWORD=das_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ------------------------------------------------------------------
# FRONTEND (Next.js)    →  ver frontend/.env.example
# ------------------------------------------------------------------

# URL del backend, usada en las llamadas fetch del frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
