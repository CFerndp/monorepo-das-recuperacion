# frontend/.env.example
#
# Plantilla de variables de entorno para el frontend Next.js.
#
# CUÁNDO necesitas este fichero:
#   - En desarrollo local NORMAL no lo necesitas si usas la URL del backend
#     directamente en tu código (http://localhost:8000).
#   - Copia este fichero como .env.local si quieres configurar la URL del
#     backend mediante una variable de entorno en lugar de tenerla hardcodeada.
#
# CÓMO usarlo:
#   cp frontend/.env.example frontend/.env.local
#   (luego edita frontend/.env.local con tus valores)
#
# IMPORTANTE: .env.local nunca se sube al repositorio (está en .gitignore).
#             .env.example SÍ se sube: es la plantilla compartida con el equipo.

# ------------------------------------------------------------------
# BACKEND
# ------------------------------------------------------------------

# URL base de la API del backend Django
# Cámbiala si tu backend corre en un puerto distinto
NEXT_PUBLIC_API_URL=http://localhost:8000
