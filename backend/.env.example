# backend/.env.example
#
# Plantilla de variables de entorno para el backend Django.
#
# CUÁNDO necesitas este fichero:
#   - En desarrollo local NORMAL no lo necesitas. Django usa SQLite por defecto
#     y arranca sin ninguna configuración extra.
#   - Copia este fichero como .env (en esta misma carpeta) solo si quieres
#     conectar Django a una base de datos PostgreSQL local.
#
# CÓMO usarlo:
#   cp backend/.env.example backend/.env
#   (luego edita backend/.env con tus valores)
#
# IMPORTANTE: .env nunca se sube al repositorio (está en .gitignore).
#             .env.example SÍ se sube: es la plantilla compartida con el equipo.

# ------------------------------------------------------------------
# BASE DE DATOS
# ------------------------------------------------------------------

# Cambia a true si quieres usar PostgreSQL en vez de SQLite
USE_POSTGRES=true

# Datos de conexión a PostgreSQL (solo relevantes si USE_POSTGRES=true)
POSTGRES_DB=das_db
POSTGRES_USER=das_user
POSTGRES_PASSWORD=das_password
POSTGRES_HOST=localhost   # "localhost" si Postgres corre en tu máquina
POSTGRES_PORT=5432
